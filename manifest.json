{
  "manifest_version": 3,
  "name": "StudySnap",
  "version": "1.0",
  "description": "Capture YouTube screenshots seamlessly into Notion.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "commands"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://api.notion.com/*",
    "https://freeimage.host/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "take_screenshot": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Take a screenshot of the saved zone on YouTube"
    },
    "take_fullscreen_screenshot": {
      "suggested_key": {
        "default": "Alt+F",
        "mac": "Alt+F"
      },
      "description": "Take a full screen screenshot on YouTube"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["styles/content.css"]
    }
  ]
}
